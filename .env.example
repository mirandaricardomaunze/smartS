# ==============================================================================
# SmartS — Variáveis de Ambiente
# Copiar este ficheiro para .env e preencher os valores reais.
# NUNCA commitar o .env com chaves reais.
# ==============================================================================

# --- Supabase (obrigatório) ---
# Obter em: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# --- Google OAuth ---
# Obter em: https://console.cloud.google.com/ → APIs & Services → Credentials
# Criar "OAuth 2.0 Client ID" do tipo Android/iOS para build nativa,
# ou tipo "Web application" para Expo Go / web.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com

# --- RevenueCat (Google Play Billing / subscrições) ---
# Obter em: https://app.revenuecat.com → Project Settings → API Keys
# Usar a chave PUBLIC (Google Play — começa com "goog_...")
EXPO_PUBLIC_REVENUECAT_API_KEY=goog_SEU_KEY_AQUI

# --- URLs de Deep Link ---
EXPO_PUBLIC_APP_SCHEME=smarts

# --- Sentry (opcional — monitorização de erros) ---
# Obter em: https://sentry.io → Settings → Projects → DSN
EXPO_PUBLIC_SENTRY_DSN=

# --- Supabase Service Role (APENAS para Edge Functions / backend) ---
# NUNCA expor na app mobile — usar apenas em servidores/Edge Functions
# SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY

# --- Stripe Secret Key (APENAS para Edge Functions / backend) ---
# NUNCA expor na app mobile
# STRIPE_SECRET_KEY=sk_test_SEU_KEY_AQUI
# STRIPE_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET
